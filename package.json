{
	"name": "fitness-tracker",
	"version": "0.0.1",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "concurrently -k npm:dev:js npm:dev:styles",
		"dev:js": "node build/esbuild.config.mjs",
		"dev:styles": "postcss src/main.css -o styles.css --watch",
		"build": "tsc -noEmit -skipLibCheck && npm run build:styles && npm run build:js",
		"build:js": "node build/esbuild.config.mjs production",
		"build:styles": "postcss src/main.css -o styles.css",
		"test": "node build/run-tests.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^10.0.3",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"postcss": "^8.4.49",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^15.1.0",
		"tailwindcss": "^3.4.17",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	}
}
